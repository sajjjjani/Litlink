NODE_ENV=development
PORT=5002

# Local development can use mongodb://localhost:27017/litlink.
# Deployment should use your MongoDB Atlas connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/litlink?retryWrites=true&w=majority

# Use a long random secret in production.
JWT_SECRET=replace-with-a-long-random-secret

# Optional locally. On Render, RENDER_EXTERNAL_URL is used automatically if FRONTEND_URL is empty.
FRONTEND_URL=http://localhost:5002

# Gmail/Nodemailer email settings.
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM="Litlink" <your-email@gmail.com>

# Cloudinary image upload settings.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional AI service. Leave empty unless you deploy ai_service separately.
AI_SERVICE_URL=http://localhost:8000

# Optional folder for local PDF files.
BOOK_PDF_DIR=
